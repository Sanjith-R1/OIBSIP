# Get user input
weight = float(input("Enter your weight (in kilograms): "))
height = float(input("Enter your height (in meters): "))

# Calculate BMI
bmi = weight / (height ** 2)

# Classify BMI
if 0 <= bmi < 18.5:
    category = "Underweight"
elif 18.5 <= bmi < 25:
    category = "Normal Weight"
elif 25 <= bmi < 30:
    category = "Overweight"
else:
    category = "Obese"

# Display results
print("\n===== BMI Result =====")
print(f"Your BMI is: {bmi:.2f}")
print(f"Category: {category}")
